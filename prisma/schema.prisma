datasource db {
  provider = "sqlite"
}

generator client {
    provider = "prisma-client"
    output   = "../src/lib/prisma/generated/"
}

model Client {
    idClient        Int             @id @default(autoincrement())
    name            String
    color           String          @default("#3B82F6")

    projects        Project[]
}

model Project {
    idProject       Int             @id @default(autoincrement())
    name            String
    color           String          @default("#3B82F6")
    hourlyRate      Decimal
    notes           String

    idClient        Int           
    client          Client          @relation(fields: [idClient], references: [idClient])

    tasks           Task[]
}

model Task {
    idTask          Int             @id @default(autoincrement())
    name            String
    startDateTime   DateTime
    endDateTime     DateTime
    paid            Boolean         @default(false)
    
    idProject       Int           
    project         Project         @relation(fields: [idProject], references: [idProject])
}