datasource db {
  provider = "sqlite"
}

generator client {
    provider = "prisma-client"
    output   = "../src/lib/prisma/generated/"
}

model Client {
    idClient        Int             @id @default(autoincrement())
    name            String
    color           String          @default("#3B82F6")

    projects        Project[]
}

model Project {
    idProject       Int             @id @default(autoincrement())
    name            String
    color           String          @default("#3B82F6")
    hourly_rate     Decimal
    notes           String

    idClient        Int           
    client          Client          @relation(fields: [idClient], references: [idClient])
}
